# ─── Supabase (backend — connection direta ao PostgreSQL) ────
# Substitua [YOUR-PASSWORD] pela senha real do projeto Supabase
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.mdhmbnlijiwgrdecrfeo.supabase.co:5432/postgres

SUPABASE_URL=https://mdhmbnlijiwgrdecrfeo.supabase.co
SUPABASE_PROJECT_REF=mdhmbnlijiwgrdecrfeo

# Service Role Key (obter em: Supabase → Settings → API → service_role)
# Necessária para operações admin sem RLS (ex: criar usuário pelo server)
SUPABASE_SERVICE_ROLE_KEY=OBTER_EM_SUPABASE_SETTINGS_API

# ─── Google OAuth 2.0 ────────────────────────────────────────
ADMIN_EMAIL=admjesusia@gmail.com,jesusmjunior2021@gmail.com,martjesusmartins@gmail.com
OAUTH_CLIENT_ID=SEU_CLIENT_ID.apps.googleusercontent.com
OAUTH_CLIENT_SECRET=SEU_CLIENT_SECRET

# ─── Gemini ──────────────────────────────────────────────────
GEMINI_API_KEY=SUA_GEMINI_API_KEY

# ─── Sessão Express ──────────────────────────────────────────
SESSION_SECRET=GERE_UMA_STRING_ALEATORIA_FORTE_AQUI
NODE_ENV=production
PORT=3001
